# StructOptima — Environment Secrets Template
# Copy this file to secrets.toml and fill in your values.
# NEVER commit secrets.toml to version control.

# Razorpay API Keys (get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID = "rzp_test_your_key_here"
RAZORPAY_KEY_SECRET = "your_secret_here"

# Optional: Override default report price (in paise, 4900 = ₹49)
# REPORT_PRICE_PAISE = "4900"

# Optional: Sentry DSN for error monitoring
# SENTRY_DSN = "https://your-dsn@sentry.io/project-id"
